+def _path_from_cli(raw: str) -> Path:
+    # Accept Windows-style backslash paths even on POSIX runtime.
+    return Path(raw.replace("\\", "/"))
+
+
+def _has_required_files(p: Path) -> bool:
+    return all((p / name).exists() for name in REQUIRED_FILES)
+
+
+def _first_valid_output_dir(candidates: Iterable[Path], *, context: str) -> Path:
+    tried: list[Path] = []
+    for candidate in candidates:
+        c = candidate.resolve()
+        tried.append(c)
+        if c.exists() and _has_required_files(c):
+            return c
+    tried_text = "\n".join(f"- {p}" for p in tried) if tried else "- (none)"
+    raise FileNotFoundError(
+        f"Could not resolve output_dir for {context}. Tried:\n{tried_text}\n"
+        f"Required files: {list(REQUIRED_FILES)}"
+    )
+
+
+def _coerce_to_output_dir(p: Path) -> Path:
+    # Accept any of: output_dir itself, run_dir, or meta/.
+    candidates = [
+        p,
+        p / "output",
+        p.parent / "output" if p.name == "meta" else p / "meta" / ".." / "output",
+    ]
+    return _first_valid_output_dir(candidates, context=f"input path: {p}")
